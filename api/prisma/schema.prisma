generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id @default(uuid())
  email            String?          @unique
  username         String?
  supabaseId       String           @unique
  authProvider     String           @default("email")
  isEmailVerified  Boolean          @default(false)
  credits          Int              @default(5)
  apiKeys          ApiKey[]
  scanHistory      ScanHistory[]
  organizations    Organization[]   @relation("OrgMembers")
  ownedOrgs        Organization[]   @relation("OrgOwner")
  paymentSessions  PaymentSession[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model Organization {
  id          String        @id @default(uuid())
  name        String
  owner       User          @relation("OrgOwner", fields: [ownerId], references: [id])
  ownerId     String
  slug        String        @unique
  members     User[]        @relation("OrgMembers")
  invitations Invitation[]
  apiKeys     ApiKey[]
  scanHistory ScanHistory[]
  plan        String        @default("starter")
  region      String        @default("americas")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Invitation {
  id        String   @id @default(uuid())
  email     String
  role      String
  orgId     String
  org       Organization @relation(fields: [orgId], references: [id])
  token     String   @unique
  accepted  Boolean  @default(false)
  invitedBy String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model ApiKey {
  id               String        @id @default(uuid())
  keyHash          String        @unique
  rawKey           String?
  user             User          @relation(fields: [userId], references: [id])
  userId           String
  organization     Organization? @relation(fields: [orgId], references: [id])
  orgId            String?
  stripeCustomerId String?
  plan             String        @default("starter")
  active           Boolean       @default(true)
  requestsCount    Int           @default(0)
  createdAt        DateTime      @default(now())
}

model ScanHistory {
  id             String        @id @default(uuid())
  wallet         String
  score          Int
  category       String
  flags          String[]
  user           User          @relation(fields: [userId], references: [id])
  userId         String
  organization   Organization? @relation(fields: [orgId], references: [id])
  orgId          String?
  timestamp      DateTime      @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  ip        String
  wallet    String
  score     Int
  category  String
  flags     String[]
  endpoint  String   @default("/v1/score")
  apiKeyId  String?
  orgId     String?
  timestamp DateTime @default(now())
}

model ProcessedEvent {
  id        String   @id
  type      String
  createdAt DateTime @default(now())
}

model PaymentSession {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  orgId           String?
  orgName         String?
  plan            String
  amountUsd       Float
  currency        String
  network         String
  address         String
  addressIndex    Int
  amountCrypto    String
  exchangeRate    Float
  status          String    @default("pending")
  txHash          String?
  txBroadcastAt   DateTime?
  amountReceived  Float?
  refundAddress   String?
  refundStatus    String    @default("none")
  batchId         String?
  expiresAt       DateTime
  confirmedAt     DateTime?
  createdAt       DateTime  @default(now())
}

model AddressCounter {
  id      String @id
  current Int    @default(0)
}
